# ==========================================
# BACKEND PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# 1. Core Server Configuration
# Defines the environment mode (development or production). Set to 'production' for live deployments.
NODE_ENV=production
# The port the Express application will run on. Default is usually 3001 or heavily dictated by PaaS providers.
PORT=3001
# The authenticated origin that the API expects requests from. Used natively for secure CORS configurations.
# E.g. https://your-frontend-domain.com
FRONTEND_URL=

# 2. Database Connection
# The complete connection string for your MongoDB deployment. Must be a valid URI. ALWYAS keep this hidden.
# E.g. mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/<DB_NAME>
MONGODB_URI=

# 3. Cryptography & Authentication
# High-entropy string used for generating and verifying JSON Web Tokens. Crucial for active session safety.
JWT_SECRET=

# 4. Third-Party API Keys
# Google Gemini setup. Specifically fuels the TherapyService AI logic block securely decoupled from clients.
GEMINI_API_KEY=
