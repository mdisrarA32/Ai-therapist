# ==========================================
# FRONTEND PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# 1. Hosted Core Backend Gateway 
# Controls exactly where the client sends its payload requests, including all /api/therapy routes.
# Note: Since this begins with NEXT_PUBLIC_, it WILL be shipped inherently in the client JavaScript bundle.
# ONLY put public URLs here. NEVER put private API Keys (like Gemini or JWT strings) in this file.
# E.g., https://api.your-backend-domain.com
NEXT_PUBLIC_API_URL=
